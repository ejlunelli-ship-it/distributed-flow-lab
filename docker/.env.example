# Copy to docker/.env and adjust as needed. docker/.env is git-ignored.

# --- API ---
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5080

# --- Web (SPA served by Nginx) ---
WEB_PORT=8080

# --- PostgreSQL ---
POSTGRES_USER=dfl
POSTGRES_PASSWORD=dfl
POSTGRES_DB=distributedflowlab
POSTGRES_PORT=5432

# --- RabbitMQ ---
RABBITMQ_USER=dfl
RABBITMQ_PASSWORD=dfl
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
